# PizzaDAO Mixtape - Environment Variables
# Copy this file to .env.local and fill in the values
#
# IMPORTANT: All NEXT_PUBLIC_* vars must be set at BUILD TIME for the static
# export (output: 'export') to bake them into the client bundle.
# In GitHub Actions, add these as repository secrets.

# WalletConnect project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Supabase configuration (get from your Supabase project Settings > API)
# Required for: leaderboard, listening tracker, metadata fetching
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NFT contract address on Base (ERC-1155)
# Required for: ownership verification, player access gate
# Must NOT be the zero address (0x000...000) or ownership checks will fail
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0xYourContractAddressHere

# Treasury wallet address for receiving USDC payments
# Required for: purchase flow
NEXT_PUBLIC_TREASURY_ADDRESS=0xYourTreasuryAddressHere

# USDC contract address on Base (rarely changes)
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Backend (Supabase Edge Function Secrets)
# These should be set in the Supabase dashboard under Edge Functions > Secrets,
# NOT in .env.local
# MINTER_PRIVATE_KEY=
# BASE_RPC_URL=https://mainnet.base.org
# NFT_CONTRACT_ADDRESS=  (same address as NEXT_PUBLIC_NFT_CONTRACT_ADDRESS, without the prefix)
# TREASURY_ADDRESS=
